.env.local Template
==================

# SUPABASE CONFIGURATION (required for runtime, placeholders ok for build)
# Get these from: https://app.supabase.com/project/[YOUR_PROJECT]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-key

# OPTIONAL: STRIPE PAYMENT
# Get these from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_KEY=pk_test_51234567890abcdefghijklmnop
STRIPE_SECRET_KEY=sk_test_51234567890abcdefghijklmnop

# OPTIONAL: EMAIL NOTIFICATIONS
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.1234567890abcdefghijklmnop

# OPTIONAL: ANALYTICS
# Get from: https://mixpanel.com/settings/tokens
NEXT_PUBLIC_MIXPANEL_TOKEN=abcdef1234567890

# App Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
